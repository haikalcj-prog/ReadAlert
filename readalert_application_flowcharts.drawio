  <diagram id="flow-progress" name="4.1.2.3 Reading Progress">
    <mxGraphModel dx="1600" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="c_title" value="4.1.2.3 Reading Progress Tracking Flowchart" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=22;fontStyle=1;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="1000" height="40" as="geometry" />
        </mxCell>
        <mxCell id="c_start" value="Start" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;strokeWidth=2;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="80" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="c_open" value="Open a library book or Home progress card" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EFF6FF;strokeColor=#2563EB;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="665" y="155" width="260" height="60" as="geometry" />
        </mxCell>
        <mxCell id="c_load" value="Load current page, best progress, total pages and status" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2563EB;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="660" y="245" width="270" height="70" as="geometry" />
        </mxCell>
        <mxCell id="c_input" value="Enter or adjust current page" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2563EB;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="685" y="350" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="c_valid" value="Page value valid?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="715" y="445" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="c_error" value="Clamp to 0-total pages or display input error" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="380" y="455" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="c_calc" value="Calculate reading percentage and pages read this session" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFDF5;strokeColor=#059669;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="665" y="565" width="260" height="65" as="geometry" />
        </mxCell>
